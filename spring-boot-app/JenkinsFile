pipeline {
agent {
    docker {
        image 'maven:3.9.6-eclipse-temurin-17'
        args '--entrypoint="" -v /var/run/docker.sock:/var/run/docker.sock -v /usr/bin/docker:/usr/bin/docker --group-add 110'
    }
}
  
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed'
      }
    }
    stage('Build and Test') {
    steps {
        sh 'ls -ltr'
        sh 'rm -rf spring-boot-app/target'   // ← add this line
        sh 'cd spring-boot-app && mvn clean package'
    }
}
    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://18.204.23.117:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'cd spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
        }
      }
    }
  stage('Build and Push Docker Image') {
    steps {
        withCredentials([usernamePassword(
            credentialsId: 'docker-cred',    // ← was 'github-jenkins'
            usernameVariable: 'DOCKER_USER',
            passwordVariable: 'DOCKER_PASS'
        )]) {
            sh '''
                echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                docker build -t newus3r/spring-boot-app:latest ./spring-boot-app
                docker push newus3r/spring-boot-app:latest
            '''
        }
    }
}
   stage('Update Deployment File') {
      environment {
        GIT_REPO_NAME = "java-maven-sonar-argocd"
        GIT_USER_NAME = "2255-k"
        HOME = "${env.WORKSPACE}"
      }
      steps {
        withCredentials([string(credentialsId: 'Git hub', variable: 'GITHUB_TOKEN')]) {
            sh '''
                git config --global --add safe.directory ${WORKSPACE}
                git config user.email "abanalkishanunni@gmail.com"
                git config user.name "2255-k"
                sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" spring-boot-app-manifests/deployment.yml
                git add spring-boot-app-manifests/deployment.yml
                git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
            '''
        }
      }
    }

  }
}
